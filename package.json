    "@vueuse/core": "^14.2.1",
    "dompurify": "^3.3.1",
    "gsap": "^3.12.0",
    "lenis": "^1.3.20",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "postcss": "^8.4.0",
