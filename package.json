    "gsap": "^3.12.0",
    "lenis": "^1.3.20",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "autoprefixer": "^10.4.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
