VITE_SITE_URL=https://example.com
VITE_CONTENT_SOURCE=local

# Sanity content provider
# Set VITE_CONTENT_SOURCE=sanity to enable CMS content
# VITE_SANITY_PROJECT_ID=
# VITE_SANITY_DATASET=production
# VITE_SANITY_API_VERSION=2025-01-01
# VITE_SANITY_USE_CDN=true
# VITE_SANITY_TOKEN=

# Optional future content providers
# VITE_CONTENTFUL_SPACE_ID=
# VITE_CONTENTFUL_ACCESS_TOKEN=
# VITE_CONTENTFUL_ENVIRONMENT=master
# VITE_CONTENT_API_BASE_URL=
# VITE_GOOGLE_SHEETS_FEED_URL=

# Form providers
# Supported: mock | webhook | custom | brevo | mailchimp
VITE_FORM_PROVIDER=mock
VITE_FORM_ENDPOINT=

# Newsletter providers
VITE_NEWSLETTER_PROVIDER=mock
VITE_NEWSLETTER_ENDPOINT=

# Brevo
# VITE_BREVO_API_KEY=
# VITE_BREVO_NEWSLETTER_LIST_ID=
# VITE_BREVO_CONTACT_LIST_ID=
# VITE_BREVO_SENDER_EMAIL=
# VITE_BREVO_SENDER_NAME=ILUMINATY
# VITE_BREVO_CONTACT_TO_EMAIL=
# VITE_BREVO_CONTACT_TO_NAME=Inbox

# Mailchimp
# VITE_MAILCHIMP_API_KEY=
# VITE_MAILCHIMP_SERVER_PREFIX=
# VITE_MAILCHIMP_AUDIENCE_ID=
# VITE_MAILCHIMP_NEWSLETTER_STATUS=subscribed
# VITE_MAILCHIMP_NEWSLETTER_TAGS=website-newsletter
# VITE_MAILCHIMP_CONTACT_TAGS=website-contact-form
