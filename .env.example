# Obligatorio antes del build de producción. Sin esto el build falla.
VITE_SITE_URL=https://your-domain.com
VITE_CONTENT_SOURCE=local

# Sanity content provider
# Set VITE_CONTENT_SOURCE=sanity to enable CMS content
# VITE_SANITY_PROJECT_ID=
# VITE_SANITY_DATASET=production
# VITE_SANITY_API_VERSION=2025-01-01
# VITE_SANITY_USE_CDN=true
#
# ⚠️  CORS en Sanity Dashboard (obligatorio para producción):
#    1. Ve a https://manage.sanity.io → tu proyecto → API → CORS origins
#    2. Agrega VITE_SITE_URL (ej: https://iluminaty.nyc) → Allow credentials: ✅
#    3. Agrega http://localhost:5173 para desarrollo local
#    Sin esto las peticiones fetch a la API de Sanity fallan con error CORS.

# Optional future content providers
# VITE_CONTENTFUL_SPACE_ID=
# VITE_CONTENTFUL_ACCESS_TOKEN=
# VITE_CONTENTFUL_ENVIRONMENT=master
# VITE_CONTENT_API_BASE_URL=
# VITE_GOOGLE_SHEETS_FEED_URL=

# Form providers
# Supported: mock | webhook | custom
VITE_FORM_PROVIDER=mock
VITE_FORM_ENDPOINT=

# Newsletter providers
VITE_NEWSLETTER_PROVIDER=mock
VITE_NEWSLETTER_ENDPOINT=

# Server-side integrations
# Keep provider secrets out of the client bundle.
# Use VITE_FORM_ENDPOINT / VITE_NEWSLETTER_ENDPOINT to call a serverless function,
# webhook, or backend that stores Brevo, Mailchimp, or private Sanity tokens.
